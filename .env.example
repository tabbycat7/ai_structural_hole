# Copy to .env and fill in. Never commit the real .env.
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://example.org/ai-structural-holes
OPENROUTER_X_TITLE=AI-Structural-Holes

# Local cache + output roots (optional overrides)
ASH_CACHE_DIR=.cache/llm
ASH_OUTPUT_DIR=outputs
