# Copy to .env and fill in. Never commit the real .env.
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# DeepSeek official API (https://api.deepseek.com) — used for deepseek/* models
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Qwen via Alibaba Cloud MaaS — used for qwen/* and qwen* models (e.g. qwen3.6-flash)
QWEN_API_KEY=sk-your-qwen-maas-key
# Optional: override MaaS endpoint (default is the project's Beijing deployment)
# QWEN_BASE_URL=https://llm-mvkibj7hczl2nxnk.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# Doubao via Volcengine Ark — used for doubao/* and doubao* models (e.g. doubao-seed-2-0-mini-260428)
DOUBAO_API_KEY=sk-your-doubao-ark-key
# Optional: override Ark endpoint (default: Beijing region)
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Kimi via Moonshot API — used for kimi/*, kimi*, moonshot/* and moonshot* models
MOONSHOT_API_KEY=sk-your-moonshot-key
# Disable thinking for kimi-k2.5/k2.6/k2 (default on). k2.7-code always thinks.
# KIMI_DISABLE_THINKING=1
# Optional: override endpoint (default: https://api.moonshot.cn/v1)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# MiniMax official API — used for minimax/*, minimax*, and abab* models
MINIMAX_API_KEY=sk-your-minimax-key
# Disable thinking for MiniMax-M3 (default on). Required for minimal JSON choice tasks.
# MINIMAX_DISABLE_THINKING=1
# Optional: override endpoint (default: https://api.minimaxi.com/v1)
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://example.org/ai-structural-holes
OPENROUTER_X_TITLE=AI-Structural-Holes

# Local cache + output roots (optional overrides)
ASH_CACHE_DIR=.cache/llm
ASH_OUTPUT_DIR=outputs
